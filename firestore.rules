rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────
    match /users/{userId} {
      // Public profile info (displayName, photoURL, username) is readable by anyone
      allow read: if true;

      // Only authenticated users can create their own document
      allow create: if request.auth != null && request.auth.uid == userId;

      // Users can update their own profile BUT cannot change their own 'plan' field.
      // The 'plan' field is managed server-side only (via Admin SDK / Cloud Functions).
      // Exception: admin email samirhasimov10@gmail.com can bypass this restriction for testing.
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (
             !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan'])
             || request.auth.token.email == 'samirhasimov10@gmail.com'
           );

      // Only the account owner can delete their own document
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────
    // VAULTS (Containers)
    // ─────────────────────────────────────────
    match /vaults/{vaultId} {
      // Creation: must be authenticated and set themselves as owner
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Read: public containers are open; private ones need auth + membership
      allow read: if resource.data.isPublic == true
        || (request.auth != null && (
          resource.data.ownerId == request.auth.uid ||
          request.auth.uid in resource.data.authorizedUsers
        ));

      // Delete: only the owner
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Update: owner OR authorized members (e.g. editors)
      // The ownerId field cannot be changed by anyone
      allow update: if request.auth != null
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId'])
        && (
          resource.data.ownerId == request.auth.uid ||
          request.auth.uid in resource.data.authorizedUsers ||
          request.auth.uid in request.resource.data.authorizedUsers
        );
    }

    // ─────────────────────────────────────────
    // SHARE INVITES
    // ─────────────────────────────────────────
    match /shareInvites/{inviteId} {
      allow read, write: if request.auth != null;
    }

    // ─────────────────────────────────────────
    // VAULT PERMISSIONS
    // ─────────────────────────────────────────
    match /vaultPermissions/{permissionId} {
      allow read, write: if request.auth != null;
    }

    // ─────────────────────────────────────────
    // SHARE LINKS
    // ─────────────────────────────────────────
    match /shareLinks/{linkId} {
      // Public read for token-based access (shared containers)
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─────────────────────────────────────────
    // NOTIFICATIONS
    // ─────────────────────────────────────────
    match /notifications/{notificationId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────
    // FOLLOWS
    // ─────────────────────────────────────────
    match /follows/{followId} {
      // Anyone signed-in can read follow documents (for counts / profile pages)
      allow read: if request.auth != null;

      // Document ID must be "{followerId}_{followingId}" for integrity
      allow create: if request.auth != null
        && request.resource.data.followerId == request.auth.uid
        && followId == request.auth.uid + '_' + request.resource.data.followingId;

      // Only the original follower can unfollow (delete)
      allow delete: if request.auth != null
        && resource.data.followerId == request.auth.uid;

      // No updates — must delete and re-follow
      allow update: if false;
    }
  }
}
